@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

@{
    string Mensagem = "Lista de Produtos: ";
}

<h1> Aprendendo Loops no ASP.NET </h1>

<h2> @Mensagem </h2>

@for(int i = 0; i <= 5; i++)
{
    <p> Produtos @i </p>
}
<hr>

@{
    int soma = 0;
}

<h2> Contador - Incremento </h2>

@for(int i = 1; i <= 10; i++)
{
    <p> Cont. - @i</p>
}
<hr>

<h2> Contador - Decremento </h2>

@for(int i = 10; i >= 1; i--)
{
    <p> Cont. - @i</p>
}
<hr>

<h2> Número Pares - 0 até 20 </h2>

@for(int i = 0; i <= 20; i++)
{
    int par = i % 2;

    if(par == 0)
    {
        <p> @i é número par </p>
    }

}
<hr>

<h2> Soma de todos os número - 0 até 10 </h2>

@for(int i = 0; i <= 10; i++)
{   
    soma += i;
}
<p>@soma</p>

<hr>

<h2> Gabarito das tabuadas</h2>

<div class="container-tabuadas">
    @{
        for(int j = 1; j <= 10; j++)
        {
            <div class="tabuada-item">        
                <h3> Tabuada @j </h3>

                @for(int i = 0; i <= 10; i++)
                {
                    <p> @j x @i = @(j*i) </p>
                }
                
            </div>        
        }

    }
</div>

@* Criando a nossa Primeira Lista *@

@{
    string[] produtos = {"Mouse",  "Notebook", "Desktop", "Tablet", "Carregador"}; 
}

@for(int i = 0; i < produtos.Length; i++)
{
    <h2> Meu produto é : @produtos[i] </h2>
}

